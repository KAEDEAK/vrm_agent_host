{
  "httpPort": 34560,
  "httpsPort": 34561,
  "useHttp": true,
  "useHttps": false,
  "listenLocalhostOnly": true,
  "_listenLocalhostOnly_note": "Changing this to false may expose the server to external access. Only disable it if you understand the security risks.",
  "allowedRemoteIPs": ["192.168.123.2", "192.168.123.3"],
  "_allowedRemoteIPs_note": "These are just examples. Modify them to match your environment.",
  "outputFilters":["useHttps","listenLocalhostOnly","allowedRemoteIPs"],
  "_outputFilters_note": "Keywords defined here will not appear in getstatus responses.",
  "autoPrepareSeamless": false,
  "vsync": false,
  "targetFramerate": 60,    
  "shadows": {
    "shadowStrength": 0.8,
    "shadowBias": 0.02,
    "shadowNormalBias": 0.3,
    "shadowResolution": "High",
    "_shadowResolution_note": ["Low", "Medium", "High", "VeryHigh"]
  },
  "lipSync": {
    "bandRanges": [
      { "key": "Ou", "range": [0, 250] },
      { "key": "Oh", "range": [250, 500] },
      { "key": "Aa", "range": [500, 2000] },
      { "key": "Ih", "range": [2000, 2800] },
      { "key": "Ee", "range": [2800, 3000] }
    ],
    "syncOffsetMs": 0.0,
    "syncPredictMs": 0.0,
    "enableSyncOptimization": true
  },
  "wave_playback": {
    "enabled": true,
    "port": 34560,
    "endpoint": "/waveplay/",
    "playback_mode": "immediate",
    "queue_max_size": 10,
    "allow_mode_change": true,
    "_playback_mode_note": "queue (順次再生), reject (再生中は拒否), immediate (即時再生・中断)",
    "_note": "Wave playback functionality for audio streaming and LipSync"
  },
  "camera": {
    "orthographic":false,
    "orthographicSize":0.4,
    "antiAliasing": 4,
    "_antiAliasing_note": "0=Off, 2=2x MSAA, 4=4x MSAA, 8=8x MSAA"
  },
  "fileControl":[
    {"key":"img","listing":"true"},
    {"key":"vrm","listing":"true"},
    {"key":"vrma","listing":"true"}
  ],
  "window": {
    "transparent": false,
    "transparentColor": "#000000",
    "allowDragObjects": true,
    "saveWindowBounds": true,
    "pointerEventsNone": false,
    "borderless":false,
    "magic": false,
    "stayOnTop": false,
    "position": {
      "x": 100,
      "y": 100,
      "width": 1280,
      "height": 720
    },
    "monitorIndex": 0
  },
  "materials": {
    "shadingToony": 1.0,
    "shadingShift": 0.5
  },
  "rim": {
    "color": "#48203C",
    "lightingMix": 1.0,
